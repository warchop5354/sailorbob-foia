# Root Environment Variables
# Copy to .env and customize for your environment

# Database
DATABASE_URL=postgres://foia_user:foia_pass@localhost:5432/foia_db

# Search
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=your_meili_master_key_here

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your_django_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1,foia.sailorbob.com

# File Upload Settings
MEDIA_ROOT=/srv/foia/uploads
MAX_UPLOAD_MB=100

# Features
OCR_ENABLED=true
DEBUG=false

# Backup Configuration
RCLONE_REMOTE=shared-sftp
BACKUP_REMOTE_PATH=/home/USER/foia_backups

# External Services (Optional)
SENTRY_DSN=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Domain Configuration
FRONTEND_URL=https://foia.sailorbob.com
API_URL=https://foia.sailorbob.com/api