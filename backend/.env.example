# Backend Environment Variables
# Copy to .env and customize for your environment

# Django Settings
DEBUG=true
SECRET_KEY=your_django_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1,foia.sailorbob.com

# Database
DATABASE_URL=postgres://foia_user:foia_pass@localhost:5432/foia_db

# Search Engine
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=your_meili_master_key_here
MEILI_INDEX_NAME=documents

# Cache & Task Queue
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# File Storage
MEDIA_ROOT=/srv/foia/uploads
MEDIA_URL=/media/
MAX_UPLOAD_MB=100

# Text Extraction & OCR
OCR_ENABLED=true
TESSERACT_CMD=/usr/bin/tesseract

# Security & CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://foia.sailorbob.com
CORS_ALLOW_CREDENTIALS=true

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Rate Limiting
RATE_LIMIT_ENABLED=true
SEARCH_RATE_LIMIT=100/hour
AUTH_RATE_LIMIT=10/minute

# Email (Optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@sailorbob.com

# Monitoring (Optional)
SENTRY_DSN=

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30